productos = ["laptop", "mause", "teclado", "monitor", "audifonos"]#lista de productos 
#lista de precios correspondiente a cada producto
precios = [2500000, 45000, 120000, 890000, 200000]
#funcion para mostrar el inventario de productos y precios
def mostrar_inventario(productos, precios ):
#recorre la lista de productos para mostrar cada producto con su precio
    print("INVENTARIO")
    for i in range(len(productos)):
        print(productos[i], ":", precios[i])
#fucion para sumar los precios y obtener el valor total del inventario
def calcular_valor_total(precios):
    return sum(precios)
#funcion para buscar un producto por su nombre y retornar si se encuentra o no
def buscar_producto(productos, nombre):
    for producto in productos:
        if producto.lower() == nombre.lower():#compara nombre del productos sin importar mayusculas o minisculas 
            return "producto encontrado" # muestra si el producto se encuentra en la lista
    return "producto no encontrado"# muestra si el producto no se encuentra en la lista
#funcion para encontrar el producto mas caro 
def producto_mas_caro(productos, precios):
    precio_maryor = max(precios)# busca el valor mas grande 
    posicion = precios.index(precio_maryor)# busca psicion del precio mas grande 
    return productos[posicion], precio_maryor
#funcio para montrar productos menores oiguales a un precio, ente caso el maximo 
def friltrar_prodductos_precio(productos, precios, maximo):
    print("PRODUCTOS MENORES O IGUALES",  maximo)
    for i in range(len(precios)):
        if precios[i] <= maximo:
            print(productos[i], ":", precios[i])
#funcion  para aplicar decuentos 
def aplicar_decuento(precios, porcentaje):
    precios_con_descuento = []# lista vacia para almacenar los nuevos precios con descuento
    for precio in precios:
        nuevo_precio = precio -(precio * porcentaje/100)
        precios_con_descuento.append(nuevo_precio)# agrega nuevos elementos a la lista 
    return precios_con_descuento
# funcionpara probar todas las funciones del inventario 
def probar_inventario():
    mostrar_inventario(productos,precios)
    print("-"*30)# muestra una linea de guiones para separar secciones
    total= calcular_valor_total(precios)
    print("Valor total del inventario:", total)
    print("-"*30)
    print(buscar_producto(productos, "teclado"))
    print(buscar_producto(productos, "celular"))
    print("-"*30)
    nombre_producto, precio = producto_mas_caro(productos, precios)
    print("Producto mas caro:", nombre_producto, "con un precio de", precio)
    print("-"*30)
    friltrar_prodductos_precio(productos, precios, 200000)# muestra los productos con precios menores o iguales a 200000
    print("-"*30)
    nuevos_precios = aplicar_decuento(precios, 10)# aplica descuento del 10% y los agrega a la nueva lista 
    print("Precios con descuento del 10%:")
    for i in range(len(productos)):
        print(productos[i], ":", nuevos_precios[i])
def main():# funcion principal para ejecutar el programa
    probar_inventario()# llama a la funcion para probar el inventario
main()# llama a la funcion main para ejecutar el programa
